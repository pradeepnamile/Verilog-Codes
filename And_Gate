module and_gate1(c,a,b);
  input a,b;
  output c;
  assign c=a&b;
endmodule

TESTBENCH:
module and_gate_tb();
  reg x,y;
  wire z;
  and_gate1 dut (z,x,y);
  initial
    begin
      $dumpfile("and_gate1.vcd");
      $dumpvars();
      $monitor($time,"x=%b,y=%b,z=%b",x,y,z);
      #5 x=1'b0; y=1'b0;
      #5 x=1'b0; y=1'b1;
      #5 x=1'b1; y=1'b0;
      #5 x=1'b1; y=1'b1;
      #5 $finish;
    end
endmodule

